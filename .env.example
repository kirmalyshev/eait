# eait — environment (copy to .env; .env is gitignored). No real secrets in this file.

# --- required ---
# Bot token from @BotFather: send /newbot, pick a name and a @handle, copy the token.
TELEGRAM_BOT_TOKEN=
# OpenRouter API key from https://openrouter.ai/keys — every meal photo is a billed vision call.
OPENROUTER_API_KEY=

# --- access control (STRONGLY recommended) ---
# Comma-separated Telegram user ids allowed to use the bot. Find yours by messaging
# @userinfobot. LEAVING THIS EMPTY LEAVES THE BOT OPEN: anyone who finds its @handle can
# onboard and spend your OpenRouter budget. Startup logs a warning while it is unset.
ALLOWED_USER_IDS=

# --- LLM (defaults shown) ---
LLM_PROVIDER=openrouter
LLM_MODEL=x-ai/grok-4.5       # must be a vision-capable model on OpenRouter
LLM_TIMEOUT_MS=60000

# --- storage / runtime (defaults shown) ---
DB_PATH=./data/eait.sqlite
TZ=Europe/Berlin              # daily-total date boundary is computed in this zone, not UTC
PER_USER_DAILY_PHOTO_CAP=50   # per user per day; caps spend on any single account

# --- spend cap (set this if the bot is public) ---
# Ceiling on meal analyses per DAY across every user. PER_USER_DAILY_PHOTO_CAP bounds one
# account; this bounds the bill, because a publicly linked bot has unbounded accounts.
# Empty = unlimited. Once reached, users are told to try tomorrow or self-host.
GLOBAL_DAILY_ANALYSIS_CAP=

# --- admin ---
ADMIN_USER_ID=                # Telegram user id allowed to run /stats (optional)
