# eait — environment (copy to .env; .env is gitignored). No real secrets in this file.

# --- required ---
# Bot token from @BotFather: send /newbot, pick a name and a @handle, copy the token.
TELEGRAM_BOT_TOKEN=
# OpenRouter API key from https://openrouter.ai/keys — every meal photo is a billed vision call.
OPENROUTER_API_KEY=

# --- access control (STRONGLY recommended) ---
# Comma-separated Telegram user ids allowed to use the bot. Find yours by messaging
# @userinfobot. LEAVING THIS EMPTY LEAVES THE BOT OPEN: anyone who finds its @handle can
# onboard and spend your OpenRouter budget. Startup logs a warning while it is unset.
# This is the SEED: once the admin uses /allow or /deny, the list stored in the database
# owns access and this variable is ignored (it only seeds a fresh database).
ALLOWED_USER_IDS=

# --- LLM (defaults shown) ---
LLM_PROVIDER=openrouter
# Must be a vision-capable model on OpenRouter. Note: the analyzer requests temperature 0.2
# for run-to-run consistency; OpenRouter silently IGNORES unsupported params, so on models
# without a temperature knob (some reasoning-class models) that lever is a quiet no-op.
LLM_MODEL=x-ai/grok-4.5
LLM_TIMEOUT_MS=60000

# --- storage: Postgres (defaults shown, matching the shared dev server) ---
# Start the shared dev server with `sh scripts/db.sh up` (docker-compose.infra.yml). The bot
# creates PGDATABASE on first boot if it does not exist. Per worktree, `scripts/compose-env.sh`
# rewrites PGDATABASE to eait_<branch> so parallel branches never share a database.
# PGPORT and PGPASSWORD also configure the dockerized server itself (docker-compose.infra.yml
# interpolates them), so changing them here moves both ends together.
PGHOST=127.0.0.1
PGPORT=5439
PGUSER=eait
PGPASSWORD=eait
PGDATABASE=eait
TZ=Europe/Berlin              # daily-total date boundary is computed in this zone, not UTC
PER_USER_DAILY_PHOTO_CAP=50   # per user per day; caps LLM calls on any single account (photo analyses + text Q&A + corrections)
REPLY_FORMAT=rich             # instance default: rich = Telegram rich cards (Bot API 10.1, plain fallback); plain = text with emojis. Users can override per-account in /settings → Style.

# --- spend cap (set this if the bot is public) ---
# Ceiling on LLM calls per DAY across every user (photo analyses + text routing + Q&A).
# PER_USER_DAILY_PHOTO_CAP bounds one account; this bounds the bill when a publicly linked
# bot has unbounded accounts. Empty = unlimited. Once reached, users are told to try tomorrow.
GLOBAL_DAILY_ANALYSIS_CAP=

# --- admin ---
ADMIN_USER_ID=                # Telegram user id allowed to run /stats (optional)

# --- per-worktree identity (maintained by `sh scripts/compose-env.sh`) ---
# COMPOSE_PROJECT_NAME namespaces the compose project; PGDATABASE above becomes eait_<branch>;
# PGDATABASE_TEST is the base name for throwaway test databases (read by src/testutil.ts only).
# Parallel instances also need DISTINCT bot tokens — one long-polling consumer per token.
#COMPOSE_PROJECT_NAME=eait-main
#PGDATABASE_TEST=eait_test_main
